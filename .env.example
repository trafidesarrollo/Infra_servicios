# Usuario y contraseña ADMINISTRADOR de Postgres. Solo se usa para crear los
# usuarios de cada servicio al iniciar (init-db/01-create-users.sh) — ninguna
# app se conecta con este usuario.
POSTGRES_USER=admin
POSTGRES_PASSWORD=cambiar-esta-password

# Puerto publicado al host (opcional, por si necesitás conectarte con pgAdmin
# desde afuera del droplet)
POSTGRES_PORT=5432

# Contraseña de cada usuario de servicio (uno por app). Cada uno se crea con
# permiso CREATEDB, así su propia app puede crear su base la primera vez que
# arranca (no hace falta crearla a mano).
AUTOCOTIZADOR_DB_PASSWORD=cambiar-esta-password
BRICA_STOCKINTERMEDIO_DB_PASSWORD=cambiar-esta-password
SUMIN_STOCKINTERMEDIO_DB_PASSWORD=cambiar-esta-password
