# Usuario de GitHub/organización dueño del paquete en GHCR
GITHUB_USERNAME=trafidesarrollo

# Conexión a la base compartida de Infra Servicios (usuario brica_stockintermedio,
# ya creado ahí con CREATEDB). La base se crea sola al primer arranque.
DATABASE_URL=postgresql://brica_stockintermedio:<BRICA_STOCKINTERMEDIO_DB_PASSWORD>@postgres:5432/brica_stockintermedio

# Puerto publicado al host (distinto del de sumin-stockintermedio para no chocar)
APP_PORT=8080

# Admin de la app
SEED_ADMIN_EMAIL=ventas@traficano.com
ADMIN_PASSWORD=cambiar-esta-password

# Gmail para notificaciones (Contraseña de aplicación, no la contraseña normal)
GMAIL_USER=tu-cuenta@gmail.com
GMAIL_APP_PASSWORD=contraseña-de-aplicacion-de-16-caracteres
