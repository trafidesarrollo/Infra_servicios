# Usuario de GitHub/organización dueño del paquete en GHCR
GITHUB_USERNAME=trafidesarrollo

# Conexión a la base compartida de Infra Servicios (usuario autocotizador,
# ya creado ahí con CREATEDB). La base se crea sola al primer arranque.
DATABASE_URL=postgresql://autocotizador:<AUTOCOTIZADOR_DB_PASSWORD>@postgres:5432/autocotizador

# App
NODE_ENV=production
PORT=5000
APP_PORT=5000

# Usuario administrador que se crea automáticamente al iniciar la app
ADMIN_EMAIL=admin@traficano.com
ADMIN_PASSWORD=cambiar-esta-password

# SMTP (Gmail) para notificaciones y envío de cotizaciones por email.
# SMTP_PASS es una "Contraseña de aplicación" generada en
# https://myaccount.google.com/apppasswords (no la contraseña normal de la cuenta).
SMTP_USER=tu-cuenta@gmail.com
SMTP_PASS=contraseña-de-aplicacion-de-16-caracteres
